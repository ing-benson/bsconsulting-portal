# Copiez ce fichier en ".env" et changez les valeurs avant de lancer le projet
# Ne committez JAMAIS le fichier .env réel dans un dépôt public.

# Port exposé publiquement par Nginx (le reverse proxy)
NGINX_PORT=80

# Port exposé pour phpMyAdmin
PHPMYADMIN_PORT=8081

# Base de données MySQL
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=bsconsulting
MYSQL_USER=bsconsulting_user
MYSQL_PASSWORD=change_this_password
